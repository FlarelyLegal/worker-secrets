{
  "name": "@homeflare/hfs",
  "version": "0.27.0",
  "type": "module",
  "description": "Encrypted secret vault CLI for Cloudflare Workers",
  "bin": {
    "homeflare": "./dist/homeflare.js",
    "hfs": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node scripts/bundle-worker.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest"
  },
  "keywords": [
    "cloudflare",
    "secrets",
    "vault",
    "cli"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/FlarelyLegal/worker-secrets.git",
    "directory": "hfs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "dependencies": {
    "age-encryption": "^0.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ora": "^9.3.0",
    "undici": "^7.24.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
