{
  "name": "secret-vault",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create secret-vault-db",
    "db:migrate": "wrangler d1 migrations apply secret-vault-db",
    "db:migrate:local": "wrangler d1 migrations apply secret-vault-db --local",
    "generate-keys": "node -e \"console.log('ENCRYPTION_KEY:', require('crypto').randomBytes(32).toString('hex'))\""
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.4",
    "hono": "^4.12.9",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
}
